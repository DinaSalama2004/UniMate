{
  "info": {
    "_postman_id": "unimate-api-local",
    "name": "UniMate API",
    "description": "FastAPI backend — register, login, create-admin. Set `baseUrl` if your server is not on 127.0.0.1:8000. Run **Login** first; the test script saves `access_token` for **Create admin**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "OpenAPI docs (browser)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/docs",
            "description": "Optional: open in browser for interactive Swagger UI."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 or 400\", function () {",
                  "    pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Secret123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/register",
            "description": "Creates a student user and a linked `students` row. Returns 400 if email already exists."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", json.access_token);",
                  "}",
                  "pm.test(\"Login returns token on 200\", function () {",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(json).to.have.property(\"access_token\");",
                  "        pm.expect(json).to.have.property(\"role\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Secret123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/login",
            "description": "Returns JWT `access_token` and `role`. Test script stores token in collection variable `access_token`."
          },
          "response": []
        },
        {
          "name": "Create admin (super admin only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminSecret123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/create-admin",
            "description": "Requires a valid Bearer token for the **super admin** account configured in `utils/security.py`. A normal student token will get 403. Run **Login** as super admin first, or paste a super-admin JWT into `access_token`."
          },
          "response": []
        }
      ]
    }
  ]
}
